# Server-only YouCam API credential. Never expose this as a PUBLIC_ variable.
YOUCAM_API_KEY=

# Optional API host override for testing or a regional endpoint.
YOUCAM_API_BASE=https://yce-api-01.makeupar.com

# Photo Lighting uses the official `lighting` feature by default.
# Set this to `off` to disable it, or provide another slug if your account requires one.
YOUCAM_LIGHTING_FEATURE=
